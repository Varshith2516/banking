@model Customer
<h2>Update Customer Info</h2>
<form asp-action="UpdateCustomerInfo" method="post" class="card">
    <input type="hidden" asp-for="CustomerId" />
    <label>Name</label><input asp-for="Name" />
    <label>Email</label><input asp-for="Email" />
    <label>Contact Info</label><input asp-for="ContactInfo" />
    <button type="submit">Update</button>
</form>
