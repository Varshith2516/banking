@model List<TransactionRecord>
<h2>Transactions</h2>
<p>
    <a asp-action="DepositFunds"><button>Deposit</button></a>
    <a asp-action="WithdrawFunds"><button>Withdraw</button></a>
    <a asp-action="TransferFunds"><button>Transfer</button></a>
</p>
<table>
    <tr><th>ID</th><th>Account</th><th>Type</th><th>Amount</th><th>Date</th></tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.TransactionId</td>
            <td>@item.AccountId</td>
            <td>@item.TransactionType</td>
            <td>@item.Amount</td>
            <td>@item.TransactionDate</td>
        </tr>
    }
</table>
