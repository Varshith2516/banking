@model DashboardViewModel
<h2>Transaction Summary Report</h2>
<div class="card">
    <p><strong>Total Customers:</strong> @Model.Customers</p>
    <p><strong>Total Accounts:</strong> @Model.Accounts</p>
    <p><strong>Total Transactions:</strong> @Model.Transactions</p>
    <p><strong>Total Loans:</strong> @Model.Loans</p>
    <p><strong>Total Balances:</strong> @Model.TotalBalances</p>
    <p><strong>Total Loan Amount:</strong> @Model.TotalLoans</p>
</div>
