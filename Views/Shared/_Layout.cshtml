<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Banking System</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <a asp-controller="Customer" asp-action="Index">Customers</a>
        <a asp-controller="Transaction" asp-action="Index">Transactions</a>
        <a asp-controller="Loan" asp-action="Index">Loans</a>
        <a asp-controller="Repayment" asp-action="RecordRepayment">Repayment</a>
        <a asp-controller="Report" asp-action="GetAuditLogs">Audit Logs</a>
    </nav>
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert-success">@TempData["Success"]</div>
        }
        @RenderBody()
    </div>
</body>
</html>
